	XDeath.Massacre:
		ZPOS M 5 ACS_NamedExecuteAlways("Samsara_KillCount", 0, 0)
		ZPOS N 5 A_XScream
		ZPOS O 5 A_NoBlocking
		ZPOS PQRST 5
		ZPOS U -1
		Stop
	Raise:
		ZPOS A 0 A_GiveInventory("SamsaraSOFXFlipReset")
		"####" "#" 0 A_JumpIfInventory("EnemyZorched",1,"ZorchRaise")
		ZPOS K 5
		ZPOS JIH 5
		Goto See
	Pain.ShrinkerDMG:
		ZPOS G 0
		"####" "#" 0 A_SetUserVar("user_scalex", scalex*65536.0)
		"####" "#" 0 A_SetUserVar("user_scaley", scaley*65536.0)
