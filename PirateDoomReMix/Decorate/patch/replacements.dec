ACTOR fatshotspawner_Samsara : fatshotspawner replaces fatshotspawner
{
	States
	{
	Death.ZorchPistol:
	Death.Zorch:
	Death.ZorchKamikaze:
	Death.PhasingZorch:
	Death.ZorchSpectral:
		"####" "#" 0 A_Stop
		"####" "#" 0 A_ChangeFlag("DONTCORPSE",1)
		"####" "#" 0 A_ChangeFlag("DONTGIB",1)
		"####" "#" 0 A_PlaySound("chex/zorch",CHAN_5)
		"####" "#" 0 A_NoGravity
		"####" "#" 3 ACS_NamedExecuteAlways("SamsaraDeathEffects", 0, 0)
		"####" "#" 0 A_GiveInventory("EnemyZorched",1)
		"####" "#" 3 A_SetTranslucent(0.9,0)
		"####" "#" 0 A_PLAYSOUND("cyber/death") //A_Scream
		"####" "#" 3 A_SetTranslucent(0.8,0)
		"####" "#" 0 A_NoBlocking
		"####" "#" 3 A_SetTranslucent(0.7,0)
		"####" "#" 3 A_SetTranslucent(0.6,0)
		"####" "#" 3 A_SetTranslucent(0.5,0)
		"####" "#" 3 A_SetTranslucent(0.4,0)
		"####" "#" 3 A_SetTranslucent(0.3,0)
		"####" "#" 3 A_SetTranslucent(0.2,0)
		"####" "#" 3 A_SetTranslucent(0.1,0)
		TNT1 A 1 A_SetTranslucent(1,0)
		TNT1 A 0 A_Gravity
		TNT1 A -1
		Stop
	}
}

ACTOR candelabromadeira_Samsara : candelabromadeira replaces candelabromadeira
{
	States
	{
	Spawn:
		DEMA XYZ 4 light("LOSTSOUL")
		Loop
	}
}

// Quick fix for MAP52 to prevent red armor from spawning
ACTOR NoRedArmorForYou { SpawnID 168 }