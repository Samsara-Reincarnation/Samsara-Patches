ACTOR GrogBarrel_Samsara : GrogBarrel replaces GrogBarrel
{
	+DONTRIP
	+FLOORCLIP
	Scale 0.6
	Tag "Grog Barrel"
	States
	{
	Death:
		BAGR A 5 BRIGHT
		BAGR A 5 BRIGHT A_Scream
		BAGR C 5 BRIGHT
	DeathContinue:
		BAGR D 5 BRIGHT A_Explode
		TNT1 A 0 A_Spawnitemex("explosao",20,0,40,0,0,0,0,0,0)
		BAGR E 10 BRIGHT A_quake(3,6,50,800,0)
		TNT1 A 0 A_Spawnitemex("smoke4",20,0,40,0,0,0,0,0,0)
		BAGR E 1050 BRIGHT A_BarrelDestroy
		BAGR E 5 A_Respawn
		Wait

	Death.ZorchPistol:
	Death.Zorch:
	Death.ZorchKamikaze:
	Death.PhasingZorch:
	Death.ZorchSpectral:
		BAGR A 5 BRIGHT
		BAGR A 5 BRIGHT A_Scream
		BAGR C 5 BRIGHT
		TNT1 A 0 A_SetDamageType("Zorch")
		TNT1 A 0 A_ChangeFlag("BLOODLESSIMPACT",true)
		Goto DeathContinue
	}
}

