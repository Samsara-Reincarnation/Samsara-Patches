		SUPR F 2 A_CustomMissile ("BeastBall", 45, -45, 0)
		SUPR E 1 A_FaceTarget
		SUPR F 2 A_CustomMissile ("BeastBall", 45, -45, 0)
		SUPR E 1 A_FaceTarget
		SUPR F 2 A_CustomMissile ("BeastBall", 45, -45, 0)
